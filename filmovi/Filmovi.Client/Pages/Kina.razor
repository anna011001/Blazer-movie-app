@page "/kina"
@inject HttpClient Http
@inject NavigationManager Nav

<h2 class="mb-4">Kina</h2>

@if (kina is null)
{
    <p>Učitavanje...</p>
}
else
{
    <div class="row">
        @foreach (var kino in kina)
        {
            <div class="col-md-3 mb-4">
                <div class="card h-100" style="cursor:pointer"
                     @onclick="() => OtvoriKino(kino.Id)">

                    <img class="card-img-top"
                         src="@($"images/kino{kino.Id}.jpg")"
                         style="height:180px; object-fit:cover" />

                    <div class="card-body text-center">
                        <h5 class="card-title">@kino.Naziv</h5>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {

    private List<KinoDto>? kina;

    protected override async Task OnInitializedAsync()
    {
        kina = await Http.GetFromJsonAsync<List<KinoDto>>("api/kina");
    }

    void OtvoriKino(int id)
    {
        Nav.NavigateTo($"/kino/{id}");
    }

    public class KinoDto
    {
        public int Id { get; set; }
        public string Naziv { get; set; } = "";
    }
}