@page "/kina"
@inject HttpClient Http
@inject NavigationManager Nav

<h2 class="page-title">Kina</h2>

@if (kina is null)
{
    <p>Učitavanje...</p>
}
else
{
    <div class="row g-4">
        @foreach (var kino in kina)
        {
            <div class="col-12 col-md-6">
                <div class="kino-grid-card" @onclick="() => OtvoriKino(kino.Id)">
                    <img src="@($"images/kino{kino.Id}.jpg")" alt="@kino.Naziv" />
                    <div class="kino-overlay">
                        <h3>@kino.Naziv</h3>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<KinoDto>? kina;

    protected override async Task OnInitializedAsync()
    {
        kina = await Http.GetFromJsonAsync<List<KinoDto>>("kina");
    }

    private void OtvoriKino(int id)
    {
        Nav.NavigateTo($"/kino/{id}");
    }

    public class KinoDto
    {
        public int Id { get; set; }
        public string Naziv { get; set; } = "";
    }
}